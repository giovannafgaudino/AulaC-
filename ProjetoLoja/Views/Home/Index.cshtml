@model IEnumerable<ProjetoLoja.Models.ProdutoViewModel>
@{
    ViewData["Title"] = "Lista de Produtos";
}
<div class="container mt-5 py-5">

    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Produtos em Destaques</h1>
        <p class="text-muted">Confira os produtos disponíveis em nosso estoque.</p>
        <hr class="w-25 mx-auto">
    </div>

    <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="bg-secondary text-white d-flex align-items-center justify-content-center" style="height: 200px;">
                            <i class="bi bi-box-seam display-1 opacity-25"></i>
                        </div>

                        <div class="card-body">
                            <h5 class="card-title text-dark">@item.Nome</h5>
                            <p class="card-text text-muted small">Cód: #@item.Id</p>
                            <h4 class="text-primary fw-bold">@item.Preco.ToString("C")</h4>
                        </div>

                        <div class="card-footer bg-transparent border-0 pb-3">
                            <div class="d-grid">
                                <a href="#" class="btn btn-outline-primary">Ver Detalhes</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center">
                <div class="alert alert-light py-3 shadow-sm">
                    <i class="bi bi-emoji-frown display-4"></i>
                    <p class="mt-3 text-muted">Ainda não temos produtos cadastrados.</p>
                </div>
            </div>
        }
    </div>
</div>