@model ProjetoLoja.Models.ProdutoViewModel

@{
    ViewData["Title"] = "Novo Produto";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Cadastrar Novo Produto</h4>
                </div>
                <div class="card-body">
                    <form asp-action="CadastrarProduto" method="post">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Nome" class="form-control" placeholder="Nome do produto" />
                            <label asp-for="Nome"></label>
                            <span asp-validation-for="Nome" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-4">
                            @* type="number" com step ajuda na validação nativa do navegador *@
                            <input asp-for="Preco" type="number" step="0.01" class="form-control" placeholder="0.00" />
                            <label asp-for="Preco"></label>
                            <span asp-validation-for="Preco" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">Salvar Produto</button>
                            <a asp-action="Index" class="btn text-secondary btn btn-warning">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

