@model ProjetoLoja.Models.ProdutoViewModel
@{
    ViewData["Title"] = "Editar Produto";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0"><i class="bi bi-pencil-square"></i> Editar Produto</h4>
                </div>
                <div class="card-body">
                    <form asp-controller="Produto" asp-action="EditarProduto" method="post">
                        @Html.AntiForgeryToken()

                        @* IMPORTANTE: Campo oculto para o ID. Sem ele, o Editar criará um novo produto ou dará erro *@
                        <input type="hidden" asp-for="Id" />

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Nome" class="form-control" placeholder="Nome do produto" />
                            <label asp-for="Nome"></label>
                            <span asp-validation-for="Nome" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-4">
                            <input asp-for="Preco" type="number" step="0.01" class="form-control" placeholder="0.00" />
                            <label asp-for="Preco"></label>
                            <span asp-validation-for="Preco" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-warning btn-lg fw-bold">Salvar Alterações</button>
                            <a asp-controller="Produto" asp-action="Index" class="btn btn-outline-secondary">Cancelar e Voltar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>